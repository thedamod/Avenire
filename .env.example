# Common
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/avenire

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# AI providers
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
BASETEN_API_KEY=
COHERE_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
FERMION_LIGHTWEIGHT_MISTRAL_MODEL=mistral-small-latest
FERMION_LIGHTWEIGHT_GROQ_MODEL=llama-3.1-8b-instant
FERMION_BASETEN_AGENT_MODEL=z-ai/glm-5
FERMION_BASETEN_REASONING_MODEL=moonshotai/kimi-a2.5
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Resend
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Axiom
AXIOM_TOKEN=
AXIOM_DATASET=avenire
OBSERVABILITY_ENABLED=false
OBSERVABILITY_SAMPLE_RATE=1
OBSERVABILITY_SERVICE=web

# Polar
POLAR_ACCESS_TOKEN=
POLAR_SERVER=
POLAR_WEBHOOK_SECRET=
POLAR_ORGANIZATION_ID=
POLAR_PRODUCT_ID_CORE_MONTHLY=
POLAR_PRODUCT_ID_CORE_YEARLY=
POLAR_PRODUCT_ID_SCHOLAR_MONTHLY=
POLAR_PRODUCT_ID_SCHOLAR_YEARLY=

# Billing
# Approximate chat credits using total model tokens. Default: 4000 tokens ~= 1 credit.
CHAT_TOKENS_PER_CREDIT=4000

# UploadThing
UPLOADTHING_TOKEN=

# Ingestion worker
INGESTION_WORKER_PORT=3010
INGESTION_WORKER_POLL_MS=1200
INGESTION_WORKER_CONCURRENCY=3

# Ingestion pipeline tuning
INGESTION_EMBED_BATCH_SIZE=64
INGESTION_EMBED_CONCURRENCY=2
INGESTION_DB_BATCH_SIZE=200
INGESTION_CHUNK_INSERT_BATCH_SIZE=200
INGESTION_STAGE_TIMING_LOG=true
IMAGE_ENRICHMENT_ENABLED=true
MISTRAL_IMAGE_DESCRIPTION_MODEL=pixtral-12b-latest
IMAGE_DESCRIPTION_MAX_CHARS=900
ENABLE_ASYNC_MEDIA_OPTIMIZATION=false
VIDEO_OPT_FETCH_TIMEOUT_MS=25000
COHERE_TEST_SAFE_MODE=true
COHERE_TEST_TPM_TARGET_RATIO=0.75
COHERE_TEST_TPM_HARD_CAP=100000
COHERE_TOKEN_ESTIMATE_SAFETY_FACTOR=1.4
COHERE_TEST_ADAPTIVE_MODE=true
COHERE_TEST_TPM_MIN_CAP=50000
COHERE_TEST_TPM_STEP_UP=10000
COHERE_TEST_TPM_STEP_DOWN_RATIO=0.5
COHERE_TEST_RPM_GUARD_ENABLED=true
RETRIEVAL_SUMMARY_VALIDATION_MIN_CONFIDENCE=0.65
