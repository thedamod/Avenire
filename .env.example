# Common
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/avenire
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# AI providers
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
BASETEN_API_KEY=
COHERE_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Resend
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# Axiom
AXIOM_TOKEN=
AXIOM_DATASET=avenire
OBSERVABILITY_ENABLED=false
OBSERVABILITY_SAMPLE_RATE=1
OBSERVABILITY_SERVICE=web

# Polar
POLAR_ACCESS_TOKEN=
POLAR_SERVER=
POLAR_WEBHOOK_SECRET=
POLAR_ORGANIZATION_ID=
POLAR_PRODUCT_ID_CORE_MONTHLY=
POLAR_PRODUCT_ID_CORE_YEARLY=
POLAR_PRODUCT_ID_SCHOLAR_MONTHLY=
POLAR_PRODUCT_ID_SCHOLAR_YEARLY=

# Billing
# Approximate chat credits using total model tokens. Default: 4000 tokens ~= 1 credit.
CHAT_TOKENS_PER_CREDIT=4000

# UploadThing
UPLOADTHING_TOKEN=
# Enable pre-upload hash+lookup dedupe in file explorer. Disabled by default to favor lower latency.
NEXT_PUBLIC_UPLOAD_PREUPLOAD_DEDUPE=false
# Max file size (bytes) to hash client-side for dedupe before upload. Set 0 to disable.
NEXT_PUBLIC_UPLOAD_DEDUPE_HASH_MAX_BYTES=12582912
UPLOAD_SESSION_TOKEN_SECRET=
UPLOAD_SESSION_MAX_PART_BYTES=16777216
# Optional temp dir for multipart part staging
# UPLOAD_SESSION_PARTS_DIR=/tmp/avenire-upload-session-parts

# Ingestion worker
INGESTION_WORKER_PORT=3010
INGESTION_WORKER_CONCURRENCY=3
INGESTION_WORKER_MAX_ATTEMPTS=3
INGESTION_WORKER_RETRY_BASE_MS=1200
INGESTION_WORKER_RETRY_MAX_MS=30000
INGESTION_WORKER_RECOVERY_SWEEP_MS=15000

# Ingestion pipeline tuning
INGESTION_EMBED_BATCH_SIZE=64
INGESTION_EMBED_CONCURRENCY=2
INGESTION_DB_BATCH_SIZE=200
INGESTION_CHUNK_INSERT_BATCH_SIZE=200
INGESTION_STAGE_TIMING_LOG=true
INGESTION_REMOTE_FETCH_TIMEOUT_MS=15000
INGESTION_REMOTE_FETCH_MAX_ATTEMPTS=3
IMAGE_ENRICHMENT_ENABLED=true
IMAGE_DESCRIPTION_MAX_CHARS=900
ENABLE_ASYNC_MEDIA_OPTIMIZATION=true
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_POLL_INTERVAL_MS=5000
MUX_POLL_MAX_ATTEMPTS=120
VIDEO_OPT_FETCH_TIMEOUT_MS=25000
COHERE_TEST_SAFE_MODE=true
COHERE_TEST_TPM_TARGET_RATIO=0.75
COHERE_TEST_TPM_HARD_CAP=100000
COHERE_TOKEN_ESTIMATE_SAFETY_FACTOR=1.4
COHERE_TEST_ADAPTIVE_MODE=true
COHERE_TEST_TPM_MIN_CAP=50000
COHERE_TEST_TPM_STEP_UP=10000
COHERE_TEST_TPM_STEP_DOWN_RATIO=0.5
COHERE_TEST_RPM_GUARD_ENABLED=true
RETRIEVAL_SUMMARY_VALIDATION_MIN_CONFIDENCE=0.65
RETRIEVAL_QUERY_CACHE_TTL_SECONDS=45

# Workspace realtime stream
WORKSPACE_EVENTS_STREAM_MAXLEN=5000
WORKSPACE_EVENTS_STREAM_BLOCK_MS=15000
